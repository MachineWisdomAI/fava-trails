{
  "artifacts": {
    "backend": "cli",
    "command": "fava-trails",
    "scope": "codev-artifacts/MachineWisdomAI/fava-trails"
  },
  "porch": {
    "checks": {
      "build": {
        "command": "uv run ruff check src/",
        "cwd": "."
      },
      "tests": {
        "command": "uv run pytest -v",
        "cwd": "."
      },
      "e2e_tests": {
        "skip": true
      }
    }
  },
  "forge": {
    "provider": "linear",
    "linear-team": "ENG"
  }
}
