# Project-level scope for FAVA Trail.
# Available to agents as an env var (Claude Code loads .env automatically).
# The MCP server does NOT read this — see FAVA_TRAIL_SCOPE_HINT for server-side.
# Slash-separated: company/team/project (e.g. mwai/eng/fava-trails)
FAVA_TRAIL_SCOPE=mwai/eng/my-project
